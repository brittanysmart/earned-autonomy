{
  "permissions": {
    "allow": [
      "mcp__claude-in-chrome__navigate",
      "Bash(npx tsc --noEmit*)",
      "Bash(.venv/bin/python3 audit.py)",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__new_page",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__lighthouse_audit",
      "mcp__claude-in-chrome__tabs_context_mcp",
      "Bash(ghostty +list-fonts)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/mark-context-read.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/require-context-before-commit.sh"
          }
        ]
      }
    ]
  }
}
